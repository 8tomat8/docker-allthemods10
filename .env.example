# Required
EULA=true

# Host paths
ATM10_DATA_DIR=./data
ATM10_BACKUP_DIR=./backups
ATM10_PORT=25565

# Server runtime
JVM_OPTS=-Xms2048m -Xmx4096m
MOTD=ATM10
ALLOW_FLIGHT=true
MAX_PLAYERS=10
ONLINE_MODE=true
ENABLE_WHITELIST=false
WHITELIST_USERS=
OP_USERS=
REFRESH_REMOTE_UUIDS=false

# Artifact verification
CURSEFORGE_API_KEY=replace-with-curseforge-api-key

# RCON (required for backups + restart announcements)
ENABLE_RCON=true
RCON_PORT=25575
RCON_PASSWORD=change-this-to-a-strong-rcon-password

# Backups
BACKUP_INITIAL_DELAY=2m
BACKUP_INTERVAL=4h
PRUNE_BACKUPS_DAYS=7
PRUNE_BACKUPS_COUNT=42
PAUSE_IF_NO_PLAYERS=true

# Automatic restart announcer
RESTART_INTERVAL_HOURS=24
RESTART_WARNING_MINUTES=10,5,1
